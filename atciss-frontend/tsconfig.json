{
  "compilerOptions": {
    "target": "es2018",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": [
      "jest-dom"
    ],
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/@testing-library"
    ],
    "paths": {
      "app/*": [
        "./src/app/*"
      ],
      "components/*": [
        "./src/components/*"
      ],
      "views/*": [
        "./src/views/*"
      ],
      "services/*": [
        "./src/services/*"
      ],
      "types/*": [
        "./src/types/*"
      ]
    }
  },
  "include": [
    "src",
    "e2e"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
